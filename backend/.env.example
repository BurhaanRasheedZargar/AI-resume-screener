# ---- Database ----
DATABASE_URL="postgresql://user:password@localhost:5434/resume_db?schema=public"

# ---- Auth ----
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-32+-character-random-secret"
JWT_EXPIRES_IN="7d"

# ---- Messaging / Cache ----
RABBITMQ_URL="amqp://guest:guest@localhost:5672"
REDIS_URL="redis://localhost:6379"

# ---- Server ----
NODE_ENV="development"
PORT=3000

# Comma-separated list of allowed browser origins
CORS_ORIGIN="http://localhost:5173"

# ---- Uploads ----
UPLOAD_FOLDER="./uploads"
MAX_UPLOAD_MB=5

# ---- Admin seed (optional, used by scripts/createAdmin.js) ----
# ADMIN_EMAIL="admin@resumescreener.com"
# ADMIN_PASSWORD="set-a-strong-password"
