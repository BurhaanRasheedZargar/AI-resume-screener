# ---- Infrastructure ----
RABBITMQ_URL=amqp://guest:guest@localhost:5672
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379   # optional, overrides REDIS_HOST/REDIS_PORT
UPLOAD_FOLDER=../backend/uploads

# ---- Models (defaults are free + ungated, no HF token needed) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# Higher quality (needs more RAM / a GPU):
#   LLM_MODEL=Qwen/Qwen2.5-3B-Instruct
#   LLM_MODEL=microsoft/Phi-3.5-mini-instruct
# DEVICE=cpu          # auto-detected (cuda when available) if left unset
MAX_NEW_TOKENS=320
GEN_TEMPERATURE=0.7

# ---- Behaviour ----
CACHE_TTL=3600
PREFETCH=1
LOG_LEVEL=INFO
