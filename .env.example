# Optional overrides for docker compose. Copy to .env and edit as needed.

# Must be at least 32 characters. Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-0123456789abcdef

# Public origin, only needed if the browser calls the API cross-origin.
# CORS_ORIGIN=http://your-server-ip:8080

# Host port the app is served on (use 80 on a public VM if you like).
FRONTEND_PORT=8080

# Generation model (free + ungated).
#   Higher quality (GPU / lots of RAM): Qwen/Qwen2.5-3B-Instruct, microsoft/Phi-3.5-mini-instruct
#   Low RAM (<= 12 GB box):             Qwen/Qwen2.5-0.5B-Instruct
LLM_MODEL=Qwen/Qwen2.5-1.5B-Instruct
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM precision on CPU: leave empty for float32, or set bfloat16 to roughly
# halve the LLM's memory (recommended on small VMs).
# MODEL_DTYPE=bfloat16
